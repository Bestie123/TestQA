/**
 * @param cellval - value for a cell being tried to be submitted (and thus being validated)
 * @param columnLabel - name of a column visible to a user {@link grid.p.colNames}
 * @param column - column object from {@link grid.p.colModel}
 * if any custom validation on values, input by user is needed, it should go here
 * */
validateXSS = function (cellval, columnLabel, column) {
    var arrayOfResultsToMerge = [[true]];

    /**
     * Grid Properties validation
     * */
    if (this.p.tgeEnableXSSValidation) {
        var xssValidation = [true];
        var xssThreatFindr = JIRA.iDalko.TGE.RegExpXSSThreatFinder(undefined);
        var hasXSSThreats = xssThreatFindr.hasXSSThreats(cellval);
        if (hasXSSThreats) {
            xssValidation[0] = false;
            /**
             * TODO: i18n: apply i18n to the message
             * */
            xssValidation[1] = AJS.format("XSS threat found in value (\"{1}\") of column \"{0}\". Can not use XML tags, and harmful HTML-escape characters when gd.enableXSSValidation = true", columnLabel, jQuery.jgridi.htmlEncode(cellval));
        }
        arrayOfResultsToMerge.push(xssValidation);
    }

    /**
     * Column Properties validation
     * */
    if (column && column.tgeColumnType && column.tgeColumnType.shouldValidateLinkCustomElement) {
        var linkValidation = JIRA.iDalko.TGE.link_custom_element_editrule.call(this, cellval, columnLabel);
        arrayOfResultsToMerge.push(linkValidation);
    }

    return mergeValidationResults(arrayOfResultsToMerge);
};

/**
 * @param arrayOfResults - Array with validation results for all the things validated for the grid
 * @return Array with 1'st element true only if all the validations passed, 2'nd element - message, combined from all validation messages or all the combined values
 * */
mergeValidationResults = function (arrayOfResults) {
    var validationPassed = true;
    var result = arrayOfResults[0];
    if (arrayOfResults.length > 1) {
        result = [validationPassed];
        jQuery.each(arrayOfResults, function (validationResultIdx, validationResult) {
            validationPassed = validationResult[0];
            return validationPassed;
        });
        if (!validationPassed) {
            /**
             * here an error message gets aggregated
             *
             * TODO: i18n: apply i18n to the message
             * */
            var aggregatedErrorMessage = "Validation has found errors: ";
            var nErrors = 0;
            var nSilentErrors = 0;
            jQuery.each(arrayOfResults, function (validationResultIdx, validationResult) {
                if (!validationResult[0]) {
                    if (isString(validationResult[1])) {
                        /**
                         * can also check, whether the first letter is uppercase
                         * */
                        aggregatedErrorMessage = aggregatedErrorMessage + validationResult[1] + ".";
                    }

                    nErrors++;
                    if (validationResult['silent']) {
                        nSilentErrors++;
                    }
                }
            });
            /** remove "." from the end of the message */
            var lastMessageCharIdx = aggregatedErrorMessage.length-1;
            if (aggregatedErrorMessage.length > 1 && aggregatedErrorMessage[lastMessageCharIdx] === ".") {
                aggregatedErrorMessage = aggregatedErrorMessage.substr(0, lastMessageCharIdx);
            }

            result[0] = false;
            result[1] = aggregatedErrorMessage;
            if (nSilentErrors == nErrors) {
                result['silent'] = true;
            }
        }
    }
    return result;
};

