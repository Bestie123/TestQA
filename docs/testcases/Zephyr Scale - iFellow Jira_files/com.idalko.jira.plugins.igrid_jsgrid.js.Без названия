 }

 function grid_commandInsertRows(url, gridId, changedRows, fieldId, numberOfAddedRecords, failMessage) {
        jQuery.ajax(jQuery.extend({
            url: url,
            type : "GET",
            dataType: "json",
            context: {gridId:gridId},
            success: function(data, status) {
                var runtimeErrors = _.filter(data.errors,function(error){ return error.runtime });
                var errors = _.filter(data.errors,function(error){ return !error.runtime });
                if (errors != null && errors.length > 0) {
                    var errorMessage = failMessage + "\n";
                    for (var j = 0, l = errors.length; j < l; j++) {
                        errorMessage = errorMessage + errors[j].message + "\n";
                    }
                    errorMessage = errorMessage + "\n";
                    alert(errorMessage);
                    return;
                }
                var grid = jQuery("#" + this.gridId);
                grid[0].p.addValidationErrors(runtimeErrors);
                grid.jqGridi('setGridParam', {datatype: "json"});
                grid.trigger("reloadGrid");
                var i;
                /** FIXME: we infer the inserted ids from `${the latest id} - ${number of rows for insertion}`! */
                for (i = data.id - numberOfAddedRecords + 1; i <= data.id;i++) {
                    var recId = i;
                    changedRows.push(["add",{"id":recId}]);
                }
                save("#" + fieldId, changedRows);
            },
            error: JIRA.iDalko.TGE.grids.popups.errors.createErrorPopupFromXhrError
        }, {}));
 }

    function grid_commandDuplicateRow(url, gridId, changedRows, fieldId) {
        var _ajaxCfg = $.extend({
            url: url,
            type : "GET",
            dataType: "json",
            context: {gridId:gridId},
            error: JIRA.iDalko.TGE.grids.popups.errors.createErrorPopupFromXhrError
        }, {});
        $.ajax(_ajaxCfg).done(function(editResponseBean) {
            var _addCommandOrNull = _getAddCommandFromEditResponseBeanOrNull(editResponseBean);
            changedRows = _putCommandToTheChangedRows(_addCommandOrNull, changedRows);
            save("#" + fieldId, changedRows);

            var grid = jQuery("#" + gridId);
            grid.jqGridi('setGridParam', {datatype: "json"});
            grid.trigger("reloadGrid");
        });
    }

    function _getAddCommandFromEditResponseBeanOrNull(editResponseBeanOrNone) {
        if (_.isNone(editResponseBeanOrNone)) {
            return null
        }
        var _id = editResponseBeanOrNone.id;
        if (_.isNone(_id)) {
            return null
        }
        var _ctxs = editResponseBeanOrNone.contexts;
        if (_.isNone(_ctxs)) {
            return null
        }
        var _ctx = _ctxs[_id];
        if (_.isNone(_ctx)) {
            return null;
        }
        return ["add", _ctx]
    }

    function _putCommandToTheChangedRows(commandOrNone, changedRows) {
        if (!_.isArray(changedRows)) {
            throw "JIRA.iDalko.TGE.grids.commands#_putCommandToTheChangedRows: changedRows is not an array!"
        }
        if (_.isNone(commandOrNone)) {
            return changedRows
        }
        if (!_.isArray(commandOrNone)) {
            console.error("JIRA.iDalko.TGE.grids.commands#_putCommandToTheChangedRows: the command is not an array (should be like: `[${operation :String}, ${bean}]`)");
            return changedRows
        }
        changedRows.push(commandOrNone);
        return changedRows;
    }

