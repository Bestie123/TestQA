    /**
     * the license error fix (IGRID-1703), exports {@link JIRA.iDalko.TGE.fixInvisibleLicenseErrorText}
     * */
    (function(){
        //IGRID-1703: getCSSRulesForSelector, findRuleValueByExternalCssSelector, areColorsSimilar, setColorIfVisible and fixInvisibleLicenseErrorText
        /**
         * @return cssRules for cssSelector (if present in css stylesheets)
         * example:
         *  blah.css:
         *      .aui-message.error {
         *          background: none repeat scroll 0 0 #D04437;
         *          border-color: #D04437;
         *          color: #FFFFFF;
         *      }
         *
         *  var result = _getCSSRulesForSelector('.aui-message.error');
         *  //result will be equal to '.aui-message.error { background: none repeat scroll 0 0 #D04437; border-color: #D04437; color: #FFFFFF; }'
         * */
        function _getCSSRulesForSelector(cssSelector) {
            /**
             * document.styleSheets[i].cssRules - css rules for modern browsers
             * document.styleSheets[i].rules - css rules for IE
             * */
            function _stylesheetToCssRules(stylesheet) {
                return stylesheet.cssRules? stylesheet.cssRules: stylesheet.rules
            }
            return _(document.styleSheets).reduce(function(foundRules, stylesheet) {
                var crossBrowserCssRules=_stylesheetToCssRules(stylesheet);
                if (_.isUndefined(crossBrowserCssRules)) {
                    return false;
                }
                var rules = _(crossBrowserCssRules).reduce(function(foundRules, rule) {
                    if (rule && _.isString(rule.selectorText) && _(rule.selectorText.toLowerCase().split(',')).any(function(rulePart){
                            return rulePart.endsWith(cssSelector)
                        })) {
                        if (_.isNull(foundRules)) {
                            return rule.cssText
                        }
                        return foundRules + rule.cssText
                    }
                    return foundRules
                }, null);
                if (!_.isNull(rules)) {
                    if (_.isNull(foundRules)) {
                        return rules
                    }
                    return foundRules + rules
                }
                return foundRules
            },
            null);
        }

        /**
         * @return String cssRule value for cssRuleKey from cssRules, found by cssSelector (if present in css stylesheets)
         * example:
         *  blah.css:
         *      .aui-message.error {
         *          background: none repeat scroll 0 0 #D04437;
         *          border-color: #D04437;
         *          color: #FFFFFF;
         *      }
         *
         *  var result = _findRuleValueByExternalCssSelector('.aui-message.error', 'color');
         *  //result will be equal to '#FFFFFF'
         * */
        function _findRuleValueByExternalCssSelector (cssSelector, cssRuleKey) {
            var foundCssRule = null;
            var cssRulz = _getCSSRulesForSelector(cssSelector);

            if (cssRulz) {
                var searchedRuleKeyNormalized = ' ' + cssRuleKey + ': ';
                var ruleStartIdx = cssRulz.indexOf(searchedRuleKeyNormalized) + searchedRuleKeyNormalized.length;
                if(ruleStartIdx >= 0) {
                    foundCssRule = cssRulz.substring(ruleStartIdx);
                    var ruleEndIdx = foundCssRule.indexOf(';');
                    if(ruleEndIdx > 0) {
                        return foundCssRule.substring(0,ruleEndIdx);
                    }
                }
            }
            return null;
        }

        /**
         * @return Boolean true if the color is the same as backgroundColor
         * This function could be improved - if it checks if the colors are close to each other
         * */
        function _areColorsSimilar(color1, color2) {
            if(color1 === color2 || _.isNull(color1) || _.isNull(color2) || _.isUndefined(color1) || _.isUndefined(color2)) {
                return true
            }
            var jqC1Div = $('<div>', {id: "iDalko-TGE-color-checker1", style: "display:none;"}).appendTo($("body")).css("color", color1);
            var jqC2Div = $('<div>', {id: "iDalko-TGE-color-checker2", style: "display:none;"}).appendTo($("body")).css("color", color2);
            var areColorsSame = jqC1Div.css('color') === jqC2Div.css('color');
            jqC1Div.remove();
            jqC2Div.remove();
            return areColorsSame
        }

        function _getColorsToTry(jqEl) {
            var currentColor = jqEl.css('color');
            var colorFromClassRule = _findRuleValueByExternalCssSelector('.aui-message.error', 'color');

            return [ currentColor, colorFromClassRule, '#FFFFFF', '#000000' ]
        }
