(function() {
    $.widget("ui.combobox", {
        _create: function() {
            var self = this,
                select = this.element.hide(),
                selected = select.children(":selected"),
                value = selected.val() ? selected.text() : "";
            var cellName = select.attr('id');
            var columnName = select.attr('name');
            var column = null;
            var grid = select.closest('table.ui-jqgrid-btable');
            var iRow = null;
            var iCol = null;
            var loadee = JIRA.iDalko.TGE.grids.popups.load.AutocompleteInputLoadee(columnName);
            if (cellName && grid.length == 1) {
                var iRowStr = cellName.replace('_'+columnName,'');
                try {
                    iRow = parseInt(iRowStr);
                } catch (exception) {
                    console.error("exception: ``" + exception + "`` occurred while attempting to parse an integer out of iRowStr: " + iRowStr);
                }
            }
            if (grid.length == 1) {
                iCol = getIColByColumnName(grid, columnName);
                column = findColumnInColModelAndDo(grid, columnName, function (column) {});
            }
            var input = this.input = $("<input>")
                .insertAfter(select)
                .addClass("igrid")
                .attr('id', select.attr('id') + "_input")
                .attr('tgrid_element_type', 'autocomplete_text')
                .val(value)
                .autocomplete({
                    delay: 0,
                    minLength: 0,
                    source: function(request, response) {
                        var matcher = new RegExp($.ui.autocomplete.escapeRegex(request.term), "i");
                        response(select.children("option").map(function() {
                            var text = $(this).text();
                            if (this.value !== undefined && this.value !== null && ( !request.term || matcher.test(text) )) {
                                return {
                                    label: text.replace(
                                        new RegExp(
                                            "(?![^&;]+;)(?!<[^<>]*)(" +
                                                $.ui.autocomplete.escapeRegex(request.term) +
                                                ")(?![^<>]*>)(?![^&;]+;)", "gi"
                                        ), "<strong>$1</strong>"),
                                    value: text,
                                    option: this
                                };
                            }
                        }));
                    },
                    select: function(event, ui) {
                        ui.item.option.selected = true;
                        self._trigger("selected", event, {
                            item: ui.item.option
                        });
                        jQuery(select).change();
                        jQuery(select).blur();
                    },
                    change: function(event, ui) {
                        if (!ui.item) {
                            var matcher = new RegExp("^" + $.ui.autocomplete.escapeRegex($(this).val()) + "$", "i"),
                                valid = false;
                            select.children("option").each(function() {
                                var atext = $(this).text();
                                if (typeof(atext) === 'string' && atext.match(matcher)) {
                                    this.selected = valid = true;
                                    //if got here, it means that the user typed one of the valid values for the list,
                                    //but did not click on the item. We have to fire the change event to refresh dependent (cascading)
                                    //elements if any
                                    jQuery(select).change();
                                    return false;
                                }
                            });
                            if (!valid) {
                                // remove invalid value, as it didn't match anything
                                $(this).val("");
                                select.val("");
                                input.data("autocomplete").term = "";
                                //invalid value removed and the list value is now empty. We have to fire the change event to refresh dependent (cascading)
                                //elements if any
                                jQuery(select).change();
                                return false;
                            }
                        }
                    }
                })
                .addClass("ui-widget ui-widget-content ui-corner-left");

            input.data("autocomplete")._renderItem = function(ul, item) {
                return $("<li></li>")
                    .data("item.autocomplete", item)
                    .append("<a class='igrid-autocomplete'>" + item.label + "</a>")
                    .appendTo(ul);
            };

            if (typeof iRow !== 'undefined' && iRow !== null &&
                typeof iCol !== 'undefined' && iCol !== null && grid.length == 1) {
                input.bind("keydown",function(e) {
                        var parentCell = $(select).parent("td[role='gridcell']");
                        grid.jqGridi("handleInCellKeyDown", e, grid[0], parentCell, iRow, iCol);
                });
            }
            /** for the autocomplete list custom element, the element to focus on is the text input element ( {@see input} ) */
            if (input && column) {
                column.tgeFocusElement = input;
            }

            if ($(select).attr("isInheritJiraTheme")) {
                $(input.autocomplete("widget")[0]).addClass("idalko-grid-edit");
            } else {
                $(input.autocomplete("widget")[0]).removeClass("idalko-grid-edit");
            }

            var button = this.button = $("<button type='button'>&nbsp;</button>")
                .attr("tabIndex", -1)
//                .attr("title", "Show All Items")
                .attr('id', select.attr('id') + "_button")
                .insertAfter(input)
                .button({
                    icons: {
                        primary: "ui-icon-triangle-1-s"
                    },
                    text: false
                })
                .removeClass("ui-corner-all")
                .addClass("ui-corner-right ui-button-icon")
                .addClass("igrid-button")
                .css("padding", 0)
                .css("margin", 0)
                .css("width", 20)
                .click(function() {
                    // close if already visible
                    if (input.autocomplete("widget").is(":visible")) {
                        input.autocomplete("close");
                        return;
                    }

                    // work around a bug (likely same cause as #5265)
                    $(this).blur();

                    // pass empty string as value to search for, displaying all results
                    input.autocomplete("search", "");
                    input.focus();
                });

            select.change(function() {
                var s = jQuery(this).children(":selected");
                if (s) {
                    input.val(s.text());
                } else {
                    input.val("");
                }
            });
            select.updateInput = function (text) {
                input.val(text);
            };



            setTimeout( function() {
                loadee.resolve()
            }, 0);
        },

        destroy: function() {
            this.input.remove();
            this.button.remove();
            this.element.show();
            $.Widget.prototype.destroy.call(this);
        }
    });
})();

