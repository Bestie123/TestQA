/** watches loading of the UI connected to add/ edit row popup forms */
(function(_, $, undefined){
    function _applyOrCallFunctionFn (fn, args, self) {
        self = self || this;
        var _fn = fn,
            _args = args;
        if (_.isArray(_args)) {
            return function () {
                return _fn.apply(self, _args)
            }
        }
        return function () {
            return _fn.call(self, _args)
        }
    }

    /** _loadedInputFn is a factory to define loadees */
    function _loadeeFn (name, inputSelectorFn) {
        /** a Loadee represents something to be loaded */
        return function Loadee (selectorOptions) {
            function _getStoredDeferreds(deferredStoreEl) {
                return deferredStoreEl[this.name]
            }
            function _getDeferreds () {
                var deferredsForEachEl = _.pluck($(this.loadeeDeferredStoreSelector()), this.name);
                return _.flatten(deferredsForEachEl)
            }
            function _getAllDeferredsForLoadees(loadees) {
                function _loadeeToDeferreds() {
                    return _.map(loadees, function(loadee){
                        var deferredsForEachEl = _.pluck($(loadee.loadeeDeferredStoreSelector()), loadee.name);
                        return _.flatten(deferredsForEachEl)
                    })
                }

                if(!_.isArray(loadees)) {
                    return []
                }
                var deferredArraysForLoadees = _loadeeToDeferreds();
                return _.flatten(deferredArraysForLoadees)
            }

            var _selector = _applyOrCallFunctionFn(inputSelectorFn, selectorOptions);

            return {
                name:name,
                loadeeDeferredStoreSelector: _selector,
                resolve: function(){
                    var self = this;
                    _.each($(self.loadeeDeferredStoreSelector()), function(el){
                        _.each(_getStoredDeferreds.call(self, el), function(deffered){
                            deffered.resolve()
                        })
                    })
                },
                storeDeferredInEl: function(deferred, deferredStoreEl) {
                    var deferreds = undefined;
                    if (_.isArray(deferredStoreEl[this.name])) {
                        deferreds = deferredStoreEl[this.name];
                    }
                    deferredStoreEl[this.name] = _.ipush(deferred, deferreds);
                },
                storeDeferred: function(deferred) {
                    var self = this;
                    _.each($(self.loadeeDeferredStoreSelector()), function(el) {
                        self.storeDeferredInEl(deferred,el)
                    })
                },
                getDeferreds: _getDeferreds,
                doAndResolveWhenLoadeesDone: function(dependencyLoadees, fn) {
                    var self = this;
                    if (_.isArray(dependencyLoadees) && _.isFunction(fn)) {
                        /** when all of the stored deferreds are resolved, call {@code fn} */
                        var _allDependencyDeferreds = _getAllDeferredsForLoadees(dependencyLoadees);
                        var _dependencyLoadeesResolvedPromise = $.when.apply($, _allDependencyDeferreds);
                        _dependencyLoadeesResolvedPromise.done(function(){
                            fn.call(this, fn);
                            self.resolve()
                        })
                    }
                }
            }
        }
    }

    /** autocomplete list loadees */
    (function(){
        function _autocompleteInputSelector(columnName) {
            return ".FormGrid tr#tr_" + columnName + " select"
        }
        JIRA.iDalko.TGE.grids.popups.load.AutocompleteInputLoadee = _loadeeFn(
            "autocompleteLoadee",
            _autocompleteInputSelector
        );
        JIRA.iDalko.TGE.grids.popups.load.AutocompleteColWidthSetLoadee = _loadeeFn(
            "autocompleteColWidthSetLoadee",
            _autocompleteInputSelector
        );
    })();
    /** list loadees */
    (function(){
