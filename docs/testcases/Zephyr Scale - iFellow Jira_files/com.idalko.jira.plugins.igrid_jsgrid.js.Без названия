/**
 * Searches for the given columns in the row and, when a column is found, executes doWhenFoundFn,
 * with passing rowid, columnIndex and column value to it
 * Example:
 *  GRID CONFIG:
 *  gd.columns=str,f
 *  col.str=String
 *  col.f=String Formula(str)
 *  col.f.formula={str}
 *  USAGE:
 *      var grid = jQuery("#$!gridId");
 *      getData(grid, iRow, 1, function (data,st,xhr) {
 *          if(data && data.rows && data.rows.length == 1) {
 *              var row = data.rows[0];
 *              var columns = ['f'];
 *              findValuesFromRowForColumnsInGridAnd(row, columns, grid, function (rowid, columnIdx, columnValue) {
 *                  grid.jqGridi("setCell", rowid, columnIdx, columnValue, false, false, true);
 *              });
 *          }
 *      });
 *      // will get data for the row by iRow index, and if the request is successful,
 *      // will find the data for the 'f' column and set this data to the grid
 * */
findValuesFromRowForColumnsInGridAnd = function (row, columns, grid, doWhenFoundFn) {
    if (row && row.cell && row.id && columns && typeof grid !== 'undefined' && grid.length == 1 && jQuery.isArray(columns)) {
        jQuery.each(columns, function (idx, columnId) {
            var columnIdx   = getColumnSrcIndexByName(grid, columnId),
                columnValue = row.cell[columnIdx];
            if(typeof doWhenFoundFn !== 'undefined' && jQuery.isFunction(doWhenFoundFn) ) {
                var iCol = getIColFromColumnSrcIndex(grid, columnIdx);
                doWhenFoundFn(row.id, iCol, columnValue);
            }
        });
    }
};

/**
 * @param theGrid - the grid to retrieve data for
 * @param offset - starting from which row to get data
 * @param limitRows - how many rows to get
 * @param successFn - what to do, when the data is gotten
 * Sends an AJAX request to the REST, and asks it to give the rows, stating from offset the limitRows number of rows
 * */
getData = function (theGrid, offset, limitRows, successFn) {
    if (theGrid && theGrid.length == 1) {
        var grid = theGrid[0];
        if (typeof grid.p !== 'undefined' &&
            typeof grid.p.datatype !== 'undefined') {
            var pagingData = jQuery.isFunction(grid.p.serializeGridData) ? grid.p.serializeGridData.call(grid, grid.p.postData) : grid.p.postData;
            if (offset) {
                pagingData = jQuery.extend(pagingData, {page: offset});
            }
            if (limitRows) {
                pagingData = jQuery.extend(pagingData, {rows: limitRows});
            }
            jQuery.ajax(
                jQuery.extend({
                        url: grid.p.url,
                        type: grid.p.mtype,
                        dataType: grid.p.datatype.toLowerCase(),
                        data: pagingData,
                        success: successFn
                    }, jQuery.jgridi.ajaxOptions, grid.p.ajaxGridOptions
                )
            );
        }
    }
};

