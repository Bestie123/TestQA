/** TODO: reuse {@link $.jgridi.createEl} */
jqGrid_createEl = function (cm, options, vl, ajaxso, targetSelect, masterColumnName) {
    var msl, ovm = [], $t = this, $ = jQuery;

    if (typeof(options.dataUrl) != "undefined") {
        setTimeout(function() {
            function bindEv (el, opt) {
                if($.isFunction(opt.dataInit)) {
                    opt.dataInit.call($t,el);
                }
                if(opt.dataEvents) {
                    $.each(opt.dataEvents, function() {
                        if (this.data !== undefined) {
                            $(el).bind(this.type, this.data, this.fn);
                        } else {
                            $(el).bind(this.type, this.fn);
                        }
                    });
                }
                return opt;
            }
            jQuery.ajax(jQuery.extend({
                url: options.dataUrl,
                type : "GET",
                dataType: "html",
                context: {elem:targetSelect, options:options, vl:vl},
                success: function(data, status) {
                    var a, ovm = [], elem = this.elem, vl = this.vl,
                        options = jQuery.extend({}, this.options),
                        msl = options.multiple === true;

                    a = jQuery(data).html();
                    if (a) {
                        jQuery('option', elem).remove();
                        jQuery(elem).append(a);
                        options = bindEv(elem,options);
                        if (typeof options.size === 'undefined') {
                            options.size = msl ? 3 : 1;
                        }

                        var attrName = jQuery(targetSelect).attr('id');
                        if (jQuery(targetSelect).attr("toselect")) {
                            ovm[0] = jQuery.trim(jQuery(targetSelect).attr("toselect"));
                        } else if (jQuery("select[name=" + masterColumnName + "]").attr('toselect_depend_' + attrName)) {
                            ovm[0] = jQuery.trim(jQuery("select[name=" + masterColumnName + "]").attr('toselect_depend_' + attrName));
                        }
                        else {
                            if (msl) {
                                ovm = vl.split(",");
                                ovm = jQuery.map(ovm, function(n) {
                                    return jQuery.trim(n);
                                });
                            } else {
                                ovm[0] = jQuery.trim(vl);
                            }
                        }
                        jQuery("option", elem).each(function(i) {
                            jQuery(this).attr("role", "option");
                            var text = jQuery.trim(jQuery(this).text());
                            var val = jQuery.trim(jQuery(this).val());
                            if (jQuery.inArray(text, ovm) > -1 || jQuery.inArray(val, ovm) > -1) {
                                this.selected = "selected";
                            }
                        });
                        jQuery(targetSelect).change();
                        if (targetSelect.updateInput) {
                            if (ovm == 0) {
                                ovm = "";
                            }
                            targetSelect.updateInput(ovm);
                        }
                        targetSelect.addClass('content-ready');
                    }
                }
            }, ajaxso || {})),
                800
        });
    } else {
        console.error("List must have dataUrl!");
    }
};

