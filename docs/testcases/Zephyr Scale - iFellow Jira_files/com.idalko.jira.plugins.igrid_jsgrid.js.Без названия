function deleteUnfocusEventListener() {
    $(".inline-edit-fields").unbind();
}

function checkParentNameRemoveListener() {
    if (typeof ServiceDesk !== "undefined") {
        if (!ServiceDesk.Customer) {
            var parent = $("#idalko-multi-cascade-field-group").parent().parent();
            if (parent.hasClass("inline-edit-fields")) {
                setInterval(deleteUnfocusEventListener, 5)
            }
        }
    }
}

function addSelect2(level) {
    checkParentNameRemoveListener();
    level.select2({
        multiple: false,
        tokenSeparators: [',', ' '],
        width: 'resolve',
        ajax: {
            url: AJS.contextPath() + "/rest/idalko-igrid/1.0/multicascaderesource/options",
            dataType: "json",
            type: "GET",
            data: function (term, page) {
                var issueId = JIRA && JIRA.Issue && JIRA.Issue.getIssueId() ? JIRA.Issue.getIssueId() : '';
                return {
                    dataSourceName: level.attr("dataSourceName"),
                    query: resolveQuery(level, level.attr("customFieldId")),
                    viewColumn: level.attr("viewColumn"),
                    storeColumn: level.attr("storeColumn"),
                    columnName: level.attr("name"),
                    searchValue: term,
                    issueId: issueId
                };
            },
            results: function (data, page) {
                var results = [];
                var emptyOpt = {id: "-", text: ""};
                results.push(emptyOpt);
                if (data && data.length > 0) {
                    level.attr("viewColumn", data[0].viewColumn);
                }
                AJS.$.each(data, function (index, option) {
                    var opt = {};
                    for (var alias in option.data) {
                        var dataKey = 'data_' + alias;
                        var quotesNeededKey = 'isquotesneeded_' + alias;
                        opt[dataKey] = option.data[alias].value;
                        opt[quotesNeededKey] = option.data[alias].quotesNeeded;
                    }
                    var value = {
                        value: option.value,
                        label: option.label
                    };
                    opt['id'] = JSON.stringify(value);
                    opt['text'] = option.label;
                    results.push(opt);
                });
                return {
                    results: results
                };
            }
        }
    });

}

function addSelect2ToLevels() {
    addReloadLevelListeners();
    AJS.$.each(AJS.$(".idalko-multi-cascade-select"), function (index, element) {
        var level = AJS.$(element);
        addSelect2(level);
        fetchSelectedValue(level, getParams(level));
    });
}

function fetchSelectedValue(elem, params) {
    if (params.issueId) {
        var query = resolveQuery(elem, params.customFieldId);
        if (isQueryResolved(query)) {
            AJS.$.ajax({
                url: AJS.contextPath() + "/rest/idalko-igrid/1.0/multicascaderesource/selected-option",
                data: {
                    customFieldId: params.customFieldId.replace("customfield_", ""),
                    issueId: params.issueId,
                    levelName: params.levelName,
                    dataSourceName: params.dataSourceName,
                    query: query,
                    viewColumn: params.viewColumn,
                    storeColumn: params.storeColumn
                },
                type: 'GET',
                success: function (option) {
                    setSelectedOption(option, elem);
                },
                error: function (err) {
                    console.log(err + "Could not retrieve selected publisher's values: customfieldId = " + params.customfieldId + ", issueId = " + params.customfieldId);
                }
            });
        }
    }
}

function isQueryResolved(query) {
    return !/\{(.*?\..*?)\}/.test(query);
}

function setSelectedOption(option, elem) {
    var opt = {id: "-", text: ""};
    if (option.selected) {
        for (var alias in option.data) {
            var dataKey = 'data_' + alias;
            var quotesNeededKey = 'isquotesneeded_' + alias;
            opt[dataKey] = option.data[alias].value;
            opt[quotesNeededKey] = option.data[alias].quotesNeeded;
        }
        var value = {
            value: option.value,
            label: option.label
        };
        opt['id'] = JSON.stringify(value);
        opt['text'] = option.label;
    }

    elem.select2('data', opt);
    fillSubscribers(elem);
}

function fillSubscribers(publisher) {
    var names = parseElements(publisher.attr("subscribers"));
    var customFieldId = publisher.attr("customFieldId");
    AJS.$.each(names, function (index, name) {
        var subscriber = AJS.$("[name='" + customFieldId + ":" + name + "']");
        fetchSelectedValue(subscriber, getParams(subscriber))
    });
}

function addReloadLevelListeners() {
    var publishers = AJS.$(".publisher");
    AJS.$.each(publishers, function (index, element) {
        element.onchange = function () {
            var publisher = AJS.$(element);
            var names = parseElements(publisher.attr("subscribers"));
            var customFieldId = publisher.attr("customFieldId");
            AJS.$.each(names, function (index, name) {
                cleanLevel(AJS.$("[name='" + customFieldId + ":" + name + "']"));
            });
        }
    });
}

function cleanLevel(level) {
    level.select2('destroy');
    addSelect2(level);
    var opt = {id: "-", text: ""};
    level.select2('data', opt);
    level.select2("container").removeClass("text");
}

function resolveQuery(subscriber, customFieldId) {
    var query = subscriber.attr("query");
    if (!isQueryResolved(query)) {
        AJS.$.each(parseElements(subscriber.attr("publishers")),
            function (index, publisherName) {
                var publisher = AJS.$("[name='" + customFieldId + ":" + publisherName + "']");
                AJS.$.each(parseElements(subscriber.attr("publisher_" + publisherName)),
                    function (index, column) {
                        var selected = publisher.select2('data');
                        if (selected != null) {
                            var alias = selected.hasOwnProperty("data_" + column.toUpperCase())
                                ? selected["data_" + column.toUpperCase()]
                                : selected["data_" + column];
                            var isQuotesNeeded = selected.hasOwnProperty("isquotesneeded_" + column.toUpperCase())
                                ? selected["isquotesneeded_" + column.toUpperCase()]
                                : selected["isquotesneeded_" + column];
                            if (typeof alias !== "undefined") {
                                query = query.replace("{" + publisherName + "." + column + "}", resolveAlias(alias, isQuotesNeeded));

                            }
                        }
                    });
            });
    }
    return query;
}

function resolveAlias(alias, isQuotesNeeded) {
    if (isQuotesNeeded == true) {
        alias = "'" + alias + "'";
    }
    return alias;
}

function parseElements(list) {
    return AJS.$.grep(list.split(','), function (a) {
        return a !== "";
    });
}

function getParams(level) {
    return {
        dataSourceName: level.attr("dataSourceName"),
        query: level.attr("query"),
        viewColumn: level.attr("viewColumn"),
        storeColumn: level.attr("storeColumn"),
        name: level.attr("name"),
        customFieldId: level.attr("customFieldId"),
        issueId: level.attr("issueId"),
        levelName: level.attr("levelName"),
        initialized: level.attr("initialized")
    };
}

