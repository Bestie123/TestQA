 * JS JIRA CONFLICTS: BE AWARE:
 *  ONE CAN NOT USE NEITHER {@link JIRA.iDalko.jQuery} NOR {@link JIRA.iDalko.$} IN SELF-EXECUTING FUNCTIONS IN ANY OF THE .JS FILES!
 *  ONE CAN USE BOTH {@link JIRA.iDalko.jQuery} AND {@link JIRA.iDalko.$} in bodies of functions in the .JS files
 * */
(function (jQuery, Hashtable, HashSet, _) {

    var $ = jQuery;
    var currentJiraFormModel = {};

    /**
     * defining custom events
     * */
    organizeEventNamespace = function () {
        JIRA.iDalko.TGE.Events = JIRA.iDalko.TGE.Events || {};
        JIRA.iDalko.TGE.Events.RESIZE_GRIDS = JIRA.iDalko.TGE.Events.RESIZE_GRIDS || "resizeGrids"; // resize all grids on the page
    };

    /**
     * JIRA.iDalko variable is used as a sign, that our external js resources
     * (.js files from the "com.idalko.jira.plugins.igrid:jsgrid" web-resource: "idalko-jqGrid.js", "jira-eventHandling.js", "jquery.jqGrid.src.js") are included
     * please, use only organizeIDalkoNamespace function to create JIRA.iDalko variable!
     * please, do not move this function out from the "com.idalko.jira.plugins.igrid:jsgrid" web-resource
     * */
    organizeIDalkoNamespace = function () {
        if (!(JIRA.iDalko)) {
            JIRA.iDalko = {};
        }
        if (!(JIRA.iDalko.TGE)) {
            JIRA.iDalko.TGE = {};
        }

        JIRA.iDalko.TGE.GRID_CUSTOM_FIELD_TYPE_NAME = JIRA.iDalko.TGE.GRID_CUSTOM_FIELD_TYPE_NAME || "com.idalko.jira.plugins.igrid:tableGridCFType";

        JIRA.iDalko.TGE.onIssueActionPopupCloseHandlers = JIRA.iDalko.TGE.onIssueActionPopupCloseHandlers || new Hashtable();

        organizeEventNamespace();
    };

    organizeIDalkoGridIssueNonSpecificNamespace = function (gridId) {
        if (JIRA.iDalko.TGE.CONSTANTS) {
            if (!(JIRA.iDalko.TGE.grid[JIRA.iDalko.TGE.CONSTANTS.ISSUE_NON_SPECIFIC])) {
                JIRA.iDalko.TGE.grid[JIRA.iDalko.TGE.CONSTANTS.ISSUE_NON_SPECIFIC] = {};
            }
            if (!(JIRA.iDalko.TGE.grid[JIRA.iDalko.TGE.CONSTANTS.ISSUE_NON_SPECIFIC][gridId])) {
                JIRA.iDalko.TGE.grid[JIRA.iDalko.TGE.CONSTANTS.ISSUE_NON_SPECIFIC][gridId] = {};
            }
            /*  init issue non specific and grid prefix non specific namespace */
            if (!(JIRA.iDalko.TGE.grid[JIRA.iDalko.TGE.CONSTANTS.ISSUE_NON_SPECIFIC][gridId])) {
                JIRA.iDalko.TGE.grid[JIRA.iDalko.TGE.CONSTANTS.ISSUE_NON_SPECIFIC][gridId] = {};
            }
        }
    };

    organizeIDalkoGridNamespace = function (issueId, gridId) {
        organizeIDalkoNamespace();

        if (!(JIRA.iDalko.TGE.grid)) {
            JIRA.iDalko.TGE.grid = {};
        }
        if (!(JIRA.iDalko.TGE.grid[issueId])) {
            JIRA.iDalko.TGE.grid[issueId] = {};
        }
        if (!(JIRA.iDalko.TGE.grid[issueId][gridId])) {
            JIRA.iDalko.TGE.grid[issueId][gridId] = {};
        }

        organizeIDalkoGridIssueNonSpecificNamespace(gridId);
    };

    hackJiraAPI = function () {
        var body = jQuery(document.body);
        var isNotAdminPage = !body.hasClass("page-type-admin");
        // cache results only if not in JIRA Administration page and the hacked classes are present
        if (isNotAdminPage) {
            // IGRID-555. render grid in 'Create Issue' popup after project/issuetype change
            hackJiraFormsModel();
            // IGRID-1403. render grid in 'Create Issue' popup after issue creation with 'Create another' checked
            hackJiraFormsCreateIssueHelper();
            // IGRID-1687. prevent inline edit control from overlapping the grid on issue view
            hackJiraIssueFieldViewAndEditor();

            // rozdoum fix for IGRID-1898
            if (AJS && AJS.FormPopup && AJS.FormPopup.fn && AJS.FormPopup.fn.destroy) {
                var AJSFormPopupFnDestroy = AJS.FormPopup.fn.destroy;
                AJS.FormPopup.fn.destroy = function () {
                    var onPopupCloseHandlers = JIRA.iDalko.TGE.onIssueActionPopupCloseHandlers.values();
                    if (onPopupCloseHandlers && jQuery.isArray(onPopupCloseHandlers)) {
                        jQuery.each(onPopupCloseHandlers, function (callBackIdx, callback) {
                            callback();
                        });
                    }
                    return AJSFormPopupFnDestroy.apply(this, arguments);
                };
            }
            // END rozdoum fix for IGRID-1898
        }

        $('form[name=jiraform]').submit(function(event, skipTgeFormValidation) {
            skipTgeFormValidation = skipTgeFormValidation || false;

            var $defaultValueTextArea = $('textarea');
            var isTgeCustomFieldDefaultValueTextArea = $defaultValueTextArea.hasClass('tge-default-value-textarea');
            if (isTgeCustomFieldDefaultValueTextArea && !skipTgeFormValidation) {
                var baseUrl = $('input[title="baseURL"]').val();
                var requestUrl = baseUrl + '/rest/idalko-igrid/1.0/datagrid/validateDefinition';
                var customFieldId = $defaultValueTextArea.attr('name');
                var gridDefinition = $defaultValueTextArea.val();
                var requestData = {
                    'customFieldId': customFieldId,
                    'gridDefinition': gridDefinition
                };
                $.post(requestUrl, requestData, function(response) {
                    var errors = response.errors;
                    if (errors.length > 0) {
                        showValidationErrorsDialog(errors);
                    } else {
                        submitEditTgeDefaultValueForm();
                    }
                });
            }
            var allowFormSubmission = !isTgeCustomFieldDefaultValueTextArea || skipTgeFormValidation;
            return allowFormSubmission;
        });

        function submitEditTgeDefaultValueForm() {
            var $defaultValueTextArea = $('textarea');
            $defaultValueTextArea.addClass('ajs-dirty-warning-exempt');

            var $defaultValueForm = $defaultValueTextArea.closest('form');
            $defaultValueForm.removeProp('submitted');
            $defaultValueForm.trigger('submit', true);
        }

        function showValidationErrorsDialog(errors) {
            var dialog = new AJS.Dialog({
                width: 600,
                height: 250,
                id: "grid-configuration-validation-errors-dialog",
                closeOnOutsideClick: false
            });
            var content = '<p>' + "Do you really want to save the grid definition with the following warnings?" + '</p>';
            if (errors.length > 0) {
                var errorList = '<ul>';
                for (var i = 0; i < errors.length; i++) {
                    var error = errors[i];
                    errorList += '<li>' + error + '</li>';
                }
                errorList += '</ul>';
                content += errorList;
            }
            dialog.addPanel('Grid configuraion validation errors', content, 'grid-configuration-validation-errors-content');
            dialog.addSubmit('Save', function(dialog) {
                submitEditTgeDefaultValueForm();
                dialog.hide();
            });
            dialog.addCancel('Cancel', function(dialog) {
                dialog.hide();
            });

            dialog.gotoPage(0);
            dialog.gotoPanel(0);
            dialog.show();
        }
    };

    /**
     * basically, just hack into Jira library,
     * and cache results of model update to
     * currentJiraFormModel variable
     */
    // IGRID-555
    function hackJiraFormsModel() {
        function overrideRefreshMethod(jiraFormsModel) {
            var oldAtlassianJiraFormsModelRefresh = jiraFormsModel.prototype.refresh;
            jiraFormsModel.prototype.refresh = function () {
                currentJiraFormModel = this;
                return oldAtlassianJiraFormsModelRefresh.apply(this, arguments);
            };
        }

        // for jira 6
        if (window.JIRA && JIRA.Forms && JIRA.Forms.Model) {
            overrideRefreshMethod(JIRA.Forms.Model);
        // IGRID-3543. for jira 7.1.9 where JIRA.Forms.Model is defined asynchronously using AJS.namespace
        } else {
            var oldAjsNamespace = AJS.namespace;
            AJS.namespace = function (namespace, context, value) {
                var result = oldAjsNamespace.call(this, namespace, context, value);
                if (namespace == 'JIRA.Forms.Model') {
                    overrideRefreshMethod(JIRA.Forms.Model);
                }

                return result;
            };
        }
    }

    // rozdoum fix for IGRID-1403
    function hackJiraFormsCreateIssueHelper() {
        function overrideHandleSubmitSuccessMethod(jiraFormsCreateIssueHelper) {
            var oldJiraFormsCreateIssueHelperHandleSubmitSUccessMethod = jiraFormsCreateIssueHelper.prototype.handleSubmitSuccess;
            jiraFormsCreateIssueHelper.prototype.handleSubmitSuccess = function () {
                currentJiraFormModel = this.form.model;
                return oldJiraFormsCreateIssueHelperHandleSubmitSUccessMethod.apply(this, arguments);
            };
        }

        // for jira 6
        if (window.JIRA && JIRA.Forms && JIRA.Forms.CreateIssueHelper) {
            overrideHandleSubmitSuccessMethod(JIRA.Forms.CreateIssueHelper);
        // IGRID-3543. for jira 7.1.9 where JIRA.Forms.CreateIssueHelper is defined asynchronously using AJS.namespace
        } else {
            var oldAjsNamespace = AJS.namespace;
            AJS.namespace = function (namespace, context, value) {
                var result = oldAjsNamespace.call(this, namespace, context, value);
                if (namespace == 'JIRA.Forms.CreateIssueHelper') {
                    overrideHandleSubmitSuccessMethod(JIRA.Forms.CreateIssueHelper);
                }

                return result;
            };
        }
    }
    // END rozdoum fix for IGRID-1403

    // rozdoum fix for IGRID-1687
    function hackJiraIssueFieldViewAndEditor() {
        var proxiedDecorate = function (atlassianJRAIshuFldViewDecorate) {
            var atlassianDecorate = atlassianJRAIshuFldViewDecorate;
            return function () {
                var result = atlassianDecorate.apply(this, arguments);
                moveInlineEditTip('.value.type-tableGridCFType');
                return result;
            }
        };
        if (window.JIRA && JIRA.Issues && JIRA.Issues.IssueFieldView) {
            JIRA.Issues.IssueFieldView.prototype.decorate = proxiedDecorate(JIRA.Issues.IssueFieldView.prototype.decorate);
        }
        if (window.JIRA && JIRA.Components && JIRA.Components.IssueEditor && JIRA.Components.IssueEditor.Views && JIRA.Components.IssueEditor.Views.FieldView) {
            JIRA.Components.IssueEditor.Views.FieldView.prototype.decorate = proxiedDecorate(JIRA.Components.IssueEditor.Views.FieldView.prototype.decorate);
        }
    }
    // END rozdoum fix for IGRID-1687

    organizeIDalkoNamespace();
    $().ready(hackJiraAPI);

    function createListeners() {
        JIRA.iDalko.TGE.ListenerJournalEntry = Class.extend({
            init: function (options) {
                this.listenerFn = options.listenerFn;
            }
        });
        JIRA.iDalko.TGE.PopupListenerJournalEntry = JIRA.iDalko.TGE.ListenerJournalEntry.extend({
            TYPE:"POPUP_LISTENER",

            equals: function (searchJSON) {
                return (searchJSON.TYPE && searchJSON.TYPE === this.TYPE);
            }
        });
        JIRA.iDalko.TGE.InlineEditBlurredListenerJournalEntry = JIRA.iDalko.TGE.PopupListenerJournalEntry.extend({
            TYPE: "INLINE_EDIT_BLURRED_LISTENER"
        });
        JIRA.iDalko.TGE.ViewGridListenerJournalEntry = JIRA.iDalko.TGE.ListenerJournalEntry.extend({
            TYPE:"VIEW_GRID_LISTENER",

            init: function (options) {
                this.issueId = options.issueId;
                this.fieldId = options.fieldId;
                this.gridId = options.gridId;
                this.listenerFn = options.listenerFn;
            },
            equals: function (searchJSON) {
                var typesEqual = (searchJSON.TYPE && searchJSON.TYPE === this.TYPE);
                var issuIdNotSearchedOrEqual = (searchJSON.issueId === undefined    || this.issueId == searchJSON.issueId);
                var fieldIdNotSearchedOrEqual = (searchJSON.fieldId === undefined   || this.fieldId == searchJSON.fieldId);
                var gridIdNotSearchedOrEqual = (searchJSON.gridId === undefined     || this.gridId == searchJSON.gridId);
                return (typesEqual &&
                    issuIdNotSearchedOrEqual &&
                    fieldIdNotSearchedOrEqual &&
                    gridIdNotSearchedOrEqual);
            }
        });
        JIRA.iDalko.TGE.EditGridListenerJournalEntry = JIRA.iDalko.TGE.ViewGridListenerJournalEntry.extend({
            TYPE:"EDIT_GRID_LISTENER"
        });
    }

    $(document).ready(function() {
        createListeners();
    });

findJournalizedListener = function (listenerEntrySearchJSON, whatToDoWhenFoundFn) {

    if (JIRA.iDalko.TGE.newContentAddedListeners) {

        jQuery.each(JIRA.iDalko.TGE.newContentAddedListeners, function (idx, listenerEntry) {
            var isFound = listenerEntry.equals(listenerEntrySearchJSON);
            if (isFound) {
                whatToDoWhenFoundFn(idx, listenerEntry);
            }
            return !isFound;
        });
    }

    if (JIRA.iDalko.TGE.inlineEditBlurredListeners) {

        jQuery.each(JIRA.iDalko.TGE.inlineEditBlurredListeners, function (idx, listenerEntry) {
            var isFound = listenerEntry.equals(listenerEntrySearchJSON);
            if (isFound) {
                whatToDoWhenFoundFn(idx, listenerEntry);
            }
            return !isFound;
        });
    }
};

journalizedJiraBindNewContentAdded = function (listenerEntrySearchJSON) {
    if (!(JIRA.iDalko.TGE.newContentAddedListeners)) {
        JIRA.iDalko.TGE.newContentAddedListeners = [];
    }

    var listenerAlreadyRegistered = false;

    findJournalizedListener(listenerEntrySearchJSON, function () {
        listenerAlreadyRegistered = true;
    });

    if (!(listenerAlreadyRegistered)) {
        //console.log("Grid View Renderer (TYPE=`" + (function(t){ return (!t)? "[None]" : t })(listenerEntrySearchJSON.TYPE) + "`) for issueId=`"+ (function(iId){ return (!iId)? "[None]" : iId })(listenerEntrySearchJSON.issueId) +"` gridId=`"+ (function(gId){ return (!gId)? "[None]" : gId })(listenerEntrySearchJSON.gridId) +"` Bound!");
        JIRA.bind(JIRA.Events.NEW_CONTENT_ADDED, listenerEntrySearchJSON.listenerFn);

        JIRA.iDalko.TGE.newContentAddedListeners.push(listenerEntrySearchJSON);
    }
};


    journalizedJiraBindInlineEditBlurred = function (listenerEntrySearchJSON) {

        if (!(JIRA.iDalko.TGE.inlineEditBlurredListeners)) {
            JIRA.iDalko.TGE.inlineEditBlurredListeners = [];
        }

        var listenerAlreadyRegistered = false;

        findJournalizedListener(listenerEntrySearchJSON, function () {
            listenerAlreadyRegistered = true;
        });

        if (!(listenerAlreadyRegistered)) {

            JIRA.bind(JIRA.Events.INLINE_EDIT_BLURRED, listenerEntrySearchJSON.listenerFn);

            JIRA.iDalko.TGE.inlineEditBlurredListeners.push(listenerEntrySearchJSON);
        }
    };

journalizedJiraUnBindNewContentAdded = function (searchListenerEntry) {
    var foundListenerEntry;
    var foundListenerEntryIdx;

    findJournalizedListener(searchListenerEntry, function (index, listenerEntry) {
        foundListenerEntry = listenerEntry;
        foundListenerEntryIdx = index;
    });

    if (foundListenerEntry) {
        //console.log("Grid View Renderer (TYPE=`" + (function(t){ return (!t)? "[None]" : t })(foundListenerEntry.TYPE) + "`) for issueId=`"+ (function(iId){ return (!iId)? "[None]" : iId })(foundListenerEntry.issueId) +"` gridId=`"+ (function(gId){ return (!gId)? "[None]" : gId })(foundListenerEntry.gridId) +"` unbound!");
        JIRA.unbind(JIRA.Events.NEW_CONTENT_ADDED, foundListenerEntry.listenerFn);

        JIRA.iDalko.TGE.newContentAddedListeners.splice(foundListenerEntryIdx, 1);
    }
};

    journalizedJiraUnBindinlineEditBlurred = function (searchListenerEntry) {
        var foundListenerEntry;
        var foundListenerEntryIdx;

        findJournalizedListener(searchListenerEntry, function (index, listenerEntry) {
            foundListenerEntry = listenerEntry;
            foundListenerEntryIdx = index;
        });

        if (foundListenerEntry) {

            JIRA.unbind(JIRA.Events.INLINE_EDIT_BLURRED, foundListenerEntry.listenerFn);

            JIRA.iDalko.TGE.inlineEditBlurredListeners.splice(foundListenerEntryIdx, 1);
        }
    };

$(function(){
    journalizedJiraBindNewContentAdded (new JIRA.iDalko.TGE.PopupListenerJournalEntry({
        listenerFn:function (e, context, reason) {
            var createIssueDialog = jQuery("#create-issue-dialog");
            var editIssueDialog = jQuery("#edit-issue-dialog");
            var isEditIssueDialog = (editIssueDialog.length > 0) && !(editIssueDialog.css("visibility") === "hidden") && editIssueDialog.is(':visible');
            var isCreateIssueDialog = (createIssueDialog.length > 0) && !(createIssueDialog.css("visibility") === "hidden") && createIssueDialog.is(':visible');
            var isPopupShown = (isEditIssueDialog || isCreateIssueDialog);
            var j500Reason = (reason === undefined);
            var j600Reason = (reason === "dialogReady");
            if ((j500Reason || j600Reason) && isPopupShown) {
                var gridsContainers =  context.find("[name=idalko-grid-field]");
                var rcleanScript = /^\s*<!(?:\[CDATA\[|\-\-)/;
                var scripts;
                if (gridsContainers.length > 0) {
                    try {
                        jQuery.each(currentJiraFormModel.fields, function (i, field) {
                            var currentGridContainer = findByRelAndRemoveFound(gridsContainers, field.id);
                            if(currentGridContainer.length == 1) {
                                scripts = jQuery(field.editHtml).filter("script");
                                jQuery.each(scripts, function (scriptIdx, script) {
                                    script.type = "text/javascript";
                                    if (isIE8()) {
                                        document.getElementsByTagName('head')[0].appendChild(script);
                                    } else {
                                        document.head.appendChild(script);
                                    }
                                    jQuery.globalEval((script.text || script.textContent || script.innerHTML || "").replace(rcleanScript, "$0"));
                                });
                            }
                        });
                    } catch (exception) {
                        //do nothing
                    }
                }
            }
        }
    }));

    journalizedJiraBindInlineEditBlurred(new JIRA.iDalko.TGE.InlineEditBlurredListenerJournalEntry({

        listenerFn: function (e, context, reason) {

            if (JIRA.iDalko.TGE.grid && JIRA.iDalko.TGE.grid.ISSUE_NON_SPECIFIC && JIRA.iDalko.TGE.grid.ISSUE_NON_SPECIFIC.hasOwnProperty(context + '_grid')) {
                e.stopImmediatePropagation();
                e.preventDefault();
            }
        }})
    );

    function adjustGridCustomFieldRowZIndex(eventType, fieldType, id, adjustZIndexFn) {
        if (fieldType == JIRA.iDalko.TGE.GRID_CUSTOM_FIELD_TYPE_NAME || eventType == JIRA.Events.INLINE_EDIT_SAVE_COMPLETE) {
            var $customfieldRow = null;
            if (id) {
                $customfieldRow = $("#" + id).closest("div.wrap").closest("li.item");
            } else {
                $customfieldRow = editedTgeFields[0];
            }

            if ($customfieldRow) {
                var zIndex = $customfieldRow.css("z-index");
                adjustZIndexFn(zIndex, $customfieldRow);
            }
        }
    }

    var editedTgeFields = [];
    if (JIRA.Events &&
        JIRA.Events.INLINE_EDIT_STARTED &&
        JIRA.Events.INLINE_EDIT_SAVE_COMPLETE &&
        JIRA.Events.BEFORE_INLINE_EDIT_CANCEL) {
        JIRA.bind(JIRA.Events.INLINE_EDIT_STARTED, function (e, id, type) {
            adjustGridCustomFieldRowZIndex(e.type, type, id, function (zIndex, $customfieldRow) {
                if (zIndex === "auto" || zIndex === "inherit" || zIndex < 2) {
                    $customfieldRow.css("z-index", 2);
                    editedTgeFields.push($customfieldRow);
                }
            });
        });
        JIRA.bind(JIRA.Events.INLINE_EDIT_SAVE_COMPLETE, function (e, id, type) {
            adjustGridCustomFieldRowZIndex(e.type, type, id, function (zIndex, $customfieldRow) {
                if (zIndex !== "auto") {
                    $customfieldRow.css("z-index", "auto");
                    editedTgeFields.shift();
                }
            });
        });
        JIRA.bind(JIRA.Events.BEFORE_INLINE_EDIT_CANCEL, function (e, id, type) {
            adjustGridCustomFieldRowZIndex(e.type, type, id, function (zIndex, $customfieldRow) {
                if (zIndex !== "auto") {
                    $customfieldRow.css("z-index", "auto");
                    editedTgeFields.shift();
                }
            });
        });
    }
});

startRenderTimer = function (context, reason, issueId, gridId) {
    JIRA.iDalko.TGE.grid[issueId][gridId].isTimerStarted = true;
    setTimeout(function () {
//        console.log("Grid View Renderer for issueId=`"+ issueId +"` gridId=`"+ gridId +"` attempted to be accessed! JIRA.iDalko.TGE.grid[issueId][gridId].createViewListenerBound=`"+ JIRA.iDalko.TGE.grid[issueId][gridId].createViewListenerBound +"`");
        if (JIRA.iDalko.TGE.grid[issueId][gridId].createViewListenerBound !== undefined) {
            //console.log("Grid View Renderer for issueId=`"+ issueId +"` attempted to be accessed! JIRA.iDalko.TGE.grid[issueId][gridId].viewRenderFn=`"+ JIRA.iDalko.TGE.grid[issueId][gridId].viewRenderFn +"`");
            JIRA.iDalko.TGE.grid[issueId][gridId].viewRenderFn(context, reason);
        }
        JIRA.iDalko.TGE.grid[issueId][gridId].isTimerStarted = false;
    }, 100);
};

/**
 * unbinds all (but the ones for provided issueId) the listeners of the JIRA.Events.NEW_CONTENT_ADDED event
 * */
unbindAll = function (butIssueId) {
    for (var issueId in JIRA.iDalko.TGE.grid) {
        if (JIRA.iDalko.TGE.grid.hasOwnProperty(issueId) && (issueId !== butIssueId)) {
            for (var gridId in JIRA.iDalko.TGE.grid[issueId]) {
                var searchListenerEntry;
                if (JIRA.iDalko.TGE.grid[issueId].hasOwnProperty(gridId) && JIRA.iDalko.TGE.grid[issueId][gridId].createViewListenerBound !== undefined ) {
                    searchListenerEntry = new JIRA.iDalko.TGE.ViewGridListenerJournalEntry({
                        issueId: issueId, gridId: gridId,
                        listenerFn: JIRA.iDalko.TGE.grid[issueId][gridId].createViewListenerBound
                    });
                    journalizedJiraUnBindNewContentAdded(searchListenerEntry);
                    journalizedJiraUnBindinlineEditBlurred(searchListenerEntry);
                    JIRA.iDalko.TGE.grid[issueId][gridId].createViewListenerBound = undefined;
                    //console.log("Grid View Renderer for issueId=`"+ issueId +"` gridId=`"+ gridId +"` unbound!");
                }
                if (JIRA.iDalko.TGE.grid[issueId].hasOwnProperty(gridId) && JIRA.iDalko.TGE.grid[issueId][gridId].createEditListenerBound !== undefined) {
                    searchListenerEntry = new JIRA.iDalko.TGE.EditGridListenerJournalEntry({
                        issueId:issueId, gridId:gridId,
                        listenerFn:JIRA.iDalko.TGE.grid[issueId][gridId].createEditListenerBound
                    });
                    journalizedJiraUnBindNewContentAdded(searchListenerEntry);
                    journalizedJiraUnBindinlineEditBlurred(searchListenerEntry);
                    JIRA.iDalko.TGE.grid[issueId][gridId].createEditListenerBound = undefined;
                }
            }
        }
    }
};

bindViewRender = function (issueId, fieldId, gridId) {
    var panelRefreshed = JIRA.CONTENT_ADDED_REASON? JIRA.CONTENT_ADDED_REASON.panelRefreshed : undefined;
    var pageLoad = JIRA.CONTENT_ADDED_REASON? JIRA.CONTENT_ADDED_REASON.pageLoad : undefined;
    var newContentAddedEventHandler = function (e, context, reason) {
        var contextId = context.length > 0 ? context[0].getAttribute("contextId") : "";

        if ((reason == panelRefreshed || reason == pageLoad) && contextId === null) {
            if (!JIRA.iDalko.TGE.grid[issueId][gridId].isTimerStarted) {
                startRenderTimer(context, reason, issueId, gridId);
            }
        }

        if (contextId === "details-module" || contextId === fieldId+"-val" || contextId === "issue-content") {
            if (reason == panelRefreshed || reason == pageLoad) {
                JIRA.iDalko.TGE.grid[issueId][gridId].viewRenderFn(context, reason);
            }
        }
    };

    var listenerJournalEntry = new JIRA.iDalko.TGE.ViewGridListenerJournalEntry ({
        issueId:issueId, fieldId:fieldId, gridId:gridId,
        listenerFn:newContentAddedEventHandler
    });
    JIRA.iDalko.TGE.grid[issueId][gridId].createViewListenerBound = newContentAddedEventHandler;
    //console.log("Grid View Renderer for issueId=`"+ issueId +"` gridId=`"+ gridId +"` Bound! JIRA.iDalko.TGE.grid[issueId][gridId].createViewListenerBound=`"+ JIRA.iDalko.TGE.grid[issueId][gridId].createViewListenerBound +"`");
    journalizedJiraBindNewContentAdded (listenerJournalEntry);
};

bindEditRender = function (issueId, fieldId, gridId) {
    var newContentAddedEventHandler = function (e, context, reason) {
        if (context.length > 0) {
