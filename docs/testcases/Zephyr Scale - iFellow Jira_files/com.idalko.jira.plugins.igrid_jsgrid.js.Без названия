(function () {
    function _getColWidth($grid, columnName) {
        var column = $grid.jqGridi("getColProp", columnName);
        if (column && !_.isUndefined(column.tgeWidth) && !_.isNaN(column.tgeWidth) && !_.isNull(column.tgeWidth)) {
            return column.tgeWidth;
        }
        return -1;
    }
    function _selectWidth($grid, columnName, colWidthFn, currentWidthFn) {
        function _compareWithMaxPossibleWidth(width) {
            if (_.isNaN(width) || _.isNull(width)) {
                return -1;
            }
            var MAX_POSSIBLE_WIDTH = 600;
            if (width < MAX_POSSIBLE_WIDTH) {
                return width;
            }
            return MAX_POSSIBLE_WIDTH;
        }

        var colWidth,
            currentWidth = -1;

        /** get current width if the function available */
        if(_.isFunction(currentWidthFn)) {
            currentWidth = _compareWithMaxPossibleWidth(currentWidthFn.call(this))
        }

        /** get col.xyz.width */
        colWidthFn = (_.isFunction(colWidthFn))? colWidthFn : _getColWidth;
        colWidth = _compareWithMaxPossibleWidth(colWidthFn.call(this, $grid, columnName));

        /** pick the maximum of current width vs. col.xyz.width property value for popup form */
        return (colWidth > currentWidth)? colWidth : -1;
    }
    function applyWidthTo$el($el, width) {
        if (_.isNumber(width) && width > 0) {
            $el.css({
                width: width + "px"
            });
            console.log('applyWidthTo$el: $el.css("width")=`'+$el.css("width")+'`')
        }
    }

