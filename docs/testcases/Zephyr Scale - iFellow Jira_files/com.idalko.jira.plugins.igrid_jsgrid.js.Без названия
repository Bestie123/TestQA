radio_custom_element = function (value, options) {
    var panel = document.createElement("span");
    panel.setAttribute("role", "radio");
    panel.setAttribute("id", options.id);
    var cellName = options.id;
    var columnName = options.name;
    var column = findColumnInColModelAndDo(jQuery(this), columnName, function (column) {});
    var firstRadioInput = null;
    var gn = options.id;
    var ovm = [];
    ovm[0] = jQuery.trim(value);

    if (options.value) {
        var i;
        var so, sv, ov, rl;
        if (typeof options.value === 'string') {
            so = options.value.split(";");
            for (i = 0; i < so.length; i++) {
                sv = so[i].split(":");
                if (sv.length > 2) {
                    sv[1] = jQuery.map(sv,
                        function(n, i) {
                            if (i > 0) {
                                return n;
                            }
                        }).join(":");
                }
                ov = document.createElement("input");
                ov.setAttribute("role", "radio");
                ov.setAttribute("type", "radio");
                ov.setAttribute("name", options.id);
                if (i == 0) {
                    ov.setAttribute("checked", true);
                }
                ov.setAttribute("title", sv[1]);
                ov.value = sv[0];
                jQuery(ov).change(options.savefn);
                panel.appendChild(ov);
                if (jQuery.inArray(jQuery.trim(jQuery(ov).text()), ovm) > -1 || jQuery.inArray(jQuery.trim(jQuery(ov).val()), ovm) > -1
                    || ovm[0] === "") {
                    ov.checked = "checked";
                    ovm[0] = "checked";
                }
                if (i === 0 && column) {
                    firstRadioInput = ov;
                }
                rl = document.createElement("span");
                rl.innerHTML = sv[1];
                panel.appendChild(rl);
                var aShift = document.createTextNode("  \n");
                panel.appendChild(aShift);
            }
        } else if (typeof options.value === 'object') {
            var oSv = options.value;
            i = 0;
            for (var key in oSv) {
                if (oSv.hasOwnProperty(key)) {
                    ov = document.createElement("input");
                    ov.setAttribute("role", "input");
                    ov.setAttribute("type", "radio");
                    ov.setAttribute("name", options.id);
                    ov.setAttribute("title", oSv[key]);
                    jQuery(ov).change(options.savefn);
                    ov.value = key;
                    if (jQuery.trim(key) == jQuery.trim(ovm[0]) || jQuery.trim(oSv[key]) == jQuery.trim(ovm[0]) || ovm[0] === "") {
                        ov.checked = "checked";
                        ovm[0] = "checked";
                    }
                    if (i === 0) {
                        firstRadioInput = ov;
                    }
                    panel.appendChild(ov);
                    rl = document.createElement("span");
                    rl.innerHTML = oSv[key];
                    panel.appendChild(rl);
                    var anotherShift = document.createTextNode("  \n");
                    panel.appendChild(anotherShift);
                    i++;
                }
            }
        }
        /** for the radio custom element, the element to focus on is the first radio button ( {@see firstRadioInput} ) in the span ( {@see panel} ) */
        if (firstRadioInput && column) {
            column.tgeFocusElement = firstRadioInput;
        }
    }
    return panel;
};

