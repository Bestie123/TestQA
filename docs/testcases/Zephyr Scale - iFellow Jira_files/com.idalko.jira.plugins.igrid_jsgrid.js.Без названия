    var AbstractWikiMarkupFormatter = function(resourceName) {
        return function (gridRowNumbers, baseUrl) {
            var bUrl = baseUrl || "";

            function wrapWithWhiteSpaceNormal(content) {
                return '<div style="white-space: normal">' + content + '</div>';
            }

            return function(cellvalue, options, rowData, operation) {
                if (!cellvalue) {
                    return cellvalue;
                }
                //This code fragment is used for processing grid view
                var isGridView = operation === "add";

                var fieldId = extractFieldId(options.gid);
                var viewModel = JIRA.iDalko.TGE.managers.modelManager.getModel(fieldId).viewModel || undefined;
                if (viewModel && viewModel.records > 0 && isGridView ) {
                    //The fastest looping construct in JS which uses length caching
                    //Think about moving to binary search.
                    for (var i = 0, size = viewModel.records; i < size; i++) {
                        var row = viewModel.rows[i];
                        if (row && row.id === options.rowId) {
                            var posNumber = gridRowNumbers == "false" ? options.pos : (options.pos - 1);
                            var wikiMarkupValue = row.cell[posNumber];

                            //IGRID-3331 jqgrid uses white-space: pre css property which makes all
                            //of the \n appear as a new line. this is not expected and not consistent
                            //with other wiki markup in Jira
                            return wrapWithWhiteSpaceNormal(wikiMarkupValue);
                        }
                    }
                }

                //This code fragment is used for processing grid inline edit
                var serverResponse = {};
                try {
                    var encodedVal = encodeURIComponent(cellvalue);
                } catch (e) {
                    console.error(e);
                    return wrapWithWhiteSpaceNormal(serverResponse);
                }

                jQuery.ajax({
                        url: AJS.format('{0}/rest/idalko-igrid/1.0/datagrid/{1}?text={2}&_issueId={3}',
                        bUrl, resourceName, encodedVal, JIRA.Issue.getIssueId()
                    ),
                    async: false
                }).done(function(data) {
                    serverResponse = data;
                }).error(function(error, text, thrown){
                    console.log(text + " : " + thrown);
                });
                return wrapWithWhiteSpaceNormal(serverResponse);
            }
        }
    };

    var AbstractUnFormatter = function () {
        return function (gridRowNumbers, fieldId) {

            return function (cellvalue, options, rowData) {

                // here options do not have gid
                // var fieldId = extractFieldId(options.gid);
                var model = JIRA.iDalko.TGE.managers.modelManager.getModel(fieldId);

                if (!model){
                    console.log("No model available!");
                    return;
                }

                var position;

                if (options.pos){

                    position = gridRowNumbers == "false" ? options.pos : (options.pos - 1);
                } else {

                    position = gridRowNumbers == "false" ? rowData[0].cellIndex : (rowData[0].cellIndex - 1);
                }

                //The fastest looping construct in JS which uses length caching
                //Think about moving to binary search.
                for (var i = 0, size = model.records; i < size; i++) {
                    var row = model.rows[i];
                    if (row && row.id === options.rowId) {
                        return row.cell[position];
                    }
                }
            }
        }
    };

    var UserFormatter = function(gridRowNumbers, baseUrl, fieldId) {
        function applyUserHover(userName, userDisplayName) {
            return '<div class="user-hover" rel="' + userName + '">' + userDisplayName + '</div>';
        }

        return function(cellvalue, options, rowData, operation) {
            var isGridView = operation === "add";
            var formattedValue = null;
            if (isGridView) {
                var selectedOptionName = cellvalue;
                var viewModel = JIRA.iDalko.TGE.managers.modelManager.getModel(fieldId).viewModel || undefined;
                if (viewModel && viewModel.records > 0) {
                    for (var i = 0; i < viewModel.records; i++) {
                        var row = viewModel.rows[i];
                        if (row && row.id === options.rowId) {
                            var posNumber = gridRowNumbers == "false" ? options.pos : (options.pos - 1);
                            selectedOptionName =  row.cell[posNumber];
                            break;
                        }
                    }
                }

                formattedValue = applyUserHover(cellvalue, selectedOptionName);
            } else {
                var encodedCellValue = encodeURIComponent(cellvalue);
                var columnName = options.colModel.name;
                var issueId = JIRA.Issue.getIssueId();
                var url = AJS.format('{0}/rest/idalko-igrid/1.0/datagrid/formatUser?text={1}&_issueId={2}&_fieldId={3}&columnName={4}',
                    baseUrl, encodedCellValue, issueId, fieldId, columnName);
                jQuery.ajax({
                    type: 'get',
                    url: url,
                    async: false,
                    dataType: 'text',
                    success: function(data) {
                        formattedValue = applyUserHover(cellvalue, data);
                    },
                    error : function(jqXHR, status, error) {
                        console.log(status + " : " + error);
                    }});
            }

            return formattedValue;
        }
    };

    JIRA.iDalko.TGE.FMATTERS = JIRA.iDalko.TGE.FMATTERS || {};
    JIRA.iDalko.TGE.FMATTERS.NumberFormatter = AbstractNumberFormatter('formatNumber');
    JIRA.iDalko.TGE.FMATTERS.WikiMarkupFormatter = AbstractWikiMarkupFormatter('formatWikiMarkup');
    JIRA.iDalko.TGE.FMATTERS.AbstractUnFormatter = AbstractUnFormatter();
    JIRA.iDalko.TGE.FMATTERS.UserFormatter = UserFormatter;
})();

(function(){
    var modelManager = function createModelManager() {
    var modelByFieldId = {};

    function beforeProcessing(fieldId) {
        return function(data, status, xhr) {
            modelByFieldId[fieldId] = data || {};
        };
    }

    function getModel(fieldId) {
        return modelByFieldId[fieldId];
    }

    function updateRow(fieldId, rowId, value) {
        var model = getModel(fieldId);
        if (model && model.rows) {
            for (var i = 0, size = model.records; i < size; i++) {
                var row = model.rows[i];
                if (row.id === rowId) {
                    model.rows[i] = value;
                    break;
                }
            }
        }
    }

    return {
        beforeProcessing:   beforeProcessing,
        updateRow:          updateRow,
        getModel:           getModel
    }
};
