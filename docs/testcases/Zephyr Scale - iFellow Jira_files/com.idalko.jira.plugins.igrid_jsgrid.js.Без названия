        }
        function _subtractAutocompleteBtnWidth(width) {
            var AUTOCOMPLETE_BUTTON_WIDTH = 20;
            return width - AUTOCOMPLETE_BUTTON_WIDTH;
        }
        var width = _selectWidth($grid, columnName, _.compose(_subtractAutocompleteBtnWidth, _getColWidth), _getCurrentElementWidth);
        applyWidthTo$el($("input#" + $select.attr('id') + "_input"), width);
    };

    applyColWidthToSelectInPopup = function ($grid, $popup, $select, columnName) {
        function _getCurrentElementWidth() {
            return $select.width()
        }
