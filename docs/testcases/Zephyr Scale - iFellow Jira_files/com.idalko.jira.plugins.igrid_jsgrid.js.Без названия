JIRA.iDalko.TGE.grids.popups.recalculatePopupColumnDependencies = function (gridId, baseurl, gridResourceTypeIdentifier, issueId, fieldId, fieldConfSchemeId, pid, issueType, dataId) {
    function _$dependentInput() {
        return $("#FrmGrid_" + gridId + " .FormElement").not(function (idx, el) {
            var $el = $(el),
                grid = $('#' + gridId),
                colName = $el.attr("name"),
                column = grid.jqGridi("getColProp", colName);
            return !(column && column.isDependent)
        });
    }

    _$dependentInput().removeClass("content-ready");

    var json = {};
    var $grid = $('#' + gridId),
        grid = $grid[0],
        gridParam = grid? grid.p : null;
    var searchInputsString = "#FrmGrid_" + gridId + " input.FormElement," +
        "#FrmGrid_" + gridId + " textarea.FormElement," +
        "#FrmGrid_" + gridId + " select.FormElement";
    var inputs = jQuery(searchInputsString).not('#id_g');
    inputs.each(function(indx, element) {
        var jQElement = $(element);
        var columnName = jQElement.attr('name');
        findTGEColumnTypeByColumnNameAndDo($grid, columnName, function (columnType) {
            json = columnType.getValueFromElementIntoJSON(element, json);
        });
    });

    var rowIdOrNull = JIRA.iDalko.TGE.grids.popups.getRowIdByGridIdOrNull(gridId);
    var rowIdString = (rowIdOrNull)? rowIdOrNull : "";
    jQuery.ajax(jQuery.extend({
        url: baseurl + "/rest/idalko-igrid/1.0/" + gridResourceTypeIdentifier + "/formula?_issueId=" + issueId + "&_fieldId=" + fieldId + "&_confSchemeId=" + fieldConfSchemeId + "&pid=" + pid + "&issueType=" + issueType + "&rowid=" + rowIdString + "&_dataId=" + dataId,
        type : "POST",
        dataType: "html",
        data: {"jsonString": JSON.stringify(json)},
        success: function(data) {
            _$dependentInput().addClass("content-ready");
            if (data) {
                var responseJson = null,
                    recalculatedRow = {};
                try {
                    responseJson = JSON.parse(data);
                } catch (e) {
                    //do nothing
                }
                if (!responseJson || !responseJson.row) {
                    return
                }
                recalculatedRow = responseJson.row;
                JIRA.iDalko.TGE.applyErrors.call(gridParam, responseJson);
                _.each(inputs, function(el) {
                    var $el = $(el);
                    var columnName = $el.attr('name');
                    findTGEColumnTypeByColumnNameAndDo($grid, columnName, function (columnType, column) {
                        if (column.isDependent) {
                            columnType.setColumnValuesToPopupInput($el, column, recalculatedRow);
                        }
                    });
                });
            }
        },
        error: JIRA.iDalko.TGE.grids.popups.errors.showErrorMessageFn(gridId)
    }, {}));
};

