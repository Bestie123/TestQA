recalculateGridSize = function (gridId, maxGridHeight, minGridHeight, minRowHeight, maxRowCount, minRowCount, extraheight) {
    recalculateGridSize(gridId, maxGridHeight, minGridHeight, minRowHeight, maxRowCount, minRowCount, false, extraheight);
};

recalculateGridSize = function (gridId, maxGridHeight, minGridHeight, minRowHeight, maxRowCount, minRowCount, extraHeight) {
    var grid = jQuery("#"+gridId);
    var ids = grid.getDataIDs();
    var newGridHeight = firstRowNumTotalHeight(gridId, ids.length);

    if (maxRowCount >= 0 && (ids.length > maxRowCount)) {
        newGridHeight = firstRowNumTotalHeight(gridId, maxRowCount);
    }

    if (minRowCount >= 0 && (ids.length < minRowCount)) {
        var coefficient = 23;
        if (minRowHeight >= coefficient) {
            coefficient = minRowHeight;
        }
        newGridHeight = (firstRowNumTotalHeight(gridId, ids.length) + (minRowCount - ids.length) * coefficient);
    }

    if (maxGridHeight >= 0 && (newGridHeight > maxGridHeight)) {
        newGridHeight = maxGridHeight;
    }
    if (minGridHeight >= 0 && (newGridHeight < minGridHeight)) {
        newGridHeight = minGridHeight;
    }
    if (extraHeight > 0) {
        newGridHeight+=extraHeight;
    }
    grid.setGridHeight(newGridHeight);
};

firstRowNumTotalHeight = function (gridId, rowNumber) {
