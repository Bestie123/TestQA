(function () {
    function _getScrollHeight($el) {
        return $el.get(0).scrollHeight;
    }

    function _resizeToScrollHeight($form) {
        $form.css({
            height: _getScrollHeight($form) + "px"
        })
    }

    function _resizeToMinWithoutVerticalScrollBar($form, minHeight, decrementBy) {
        decrementBy = _.isUndefined(decrementBy)? 1 : decrementBy;
        if ($form.hasVerticalScrollBar()) {
            $form.css({
                height: (minHeight + decrementBy) + "px"
            });
            return
        }
        $form.css({
            height: minHeight + "px"
        });
        _resizeToMinWithoutVerticalScrollBar($form, minHeight - decrementBy, decrementBy)
    }

    function _popupWillFitBrowserVerticallyWithoutTheScrollBar($popup, $form) {
        var popupHeight = $popup.height();
        var formHeight = $form.height();
        if (!_.isNaN(popupHeight) && !_.isNaN(formHeight) &&
            popupHeight < formHeight) {
            return false
        }

        var formScrollHeight = _getScrollHeight($form);
        if (!_.isNaN(formScrollHeight) && !_.isNaN(formHeight) &&
            formScrollHeight < formHeight) {
            return false
        }

        var popupHeightIfFormResized = (popupHeight - formHeight) + formScrollHeight;
        if (!_.isNaN(popupHeightIfFormResized) && !_.isNaN(popupHeight) &&
            popupHeightIfFormResized < popupHeight) {
            return false
        }

        return popupHeightIfFormResized < $(window).height();
    }

    function _ensureNoVerticalScrollBar($popup) {
        var $form = $popup.find("form.FormGrid");
        var formOuterHeight = $form.outerHeight();
        if (formOuterHeight <= 0) {
            return;
        }
        if ($form.hasVerticalScrollBar() && _popupWillFitBrowserVerticallyWithoutTheScrollBar($popup, $form)) {
            _resizeToScrollHeight($form);
        }
//        if (!$form.hasVerticalScrollBar()) {
//            _resizeToMinWithoutVerticalScrollBar($form, $form.height(), 1);
//        }
    }
    function _rowWidth (row) {
        function _selectRowWidth() {
            var $row = jQuery(row);
            var $select = $row.find("select:visible");
            var maxWidthByJQuerySelector = _.max(_.map($select, function(selectEl) {
                try {
                    return parseInt(selectEl.style.width, 10)
                } catch (e) {
                    return -1
                }
            }));
            var selectWidth = $select.width();
            if(maxWidthByJQuerySelector > selectWidth) {
                return $row.width() - selectWidth + maxWidthByJQuerySelector;
            }
            return -1
        }

        var $row = jQuery(row);
        var defaultRowWidth = $row.innerWidth();
        if ($row.has("select:visible")) {
            var selectRowWidth = _selectRowWidth();
            if (selectRowWidth > defaultRowWidth) {
                return selectRowWidth
            }
        }
        return defaultRowWidth
    }

    centerAndResizePopup = function ($popup) {
        var height = $popup.innerHeight();
        /**
         * IGRID-2634, seems, that field width does not affect the
         * popup content div width in IE9,
         * thus searching for maximal row width
         * and assigning it's width to the popup
         * */
        var maxRowWidth = _.max(_.map($popup.find("tr.FormData"), _rowWidth));
        var width = $popup.innerWidth();
        var MAGIC_NUMBER_4_BORDERS_MARGINS_AND_AUTOCOMPLETE_BUTTONS = 90;
        if (maxRowWidth !== undefined && maxRowWidth > 0 &&
            width < maxRowWidth + MAGIC_NUMBER_4_BORDERS_MARGINS_AND_AUTOCOMPLETE_BUTTONS) {
            width = maxRowWidth + MAGIC_NUMBER_4_BORDERS_MARGINS_AND_AUTOCOMPLETE_BUTTONS;
        }
        $popup.css("left", "");
        $popup.css({
            width: width
        });
        _ensureNoVerticalScrollBar($popup);
        $popup.css({
            position: "fixed",
            top: "50%",
            left: "50%",
            "margin-top": - Math.round(height / 2) +"px",
            "margin-left": - Math.round(width / 2) + "px"
        });
    }
