cascade_afterShowForm = function (formid, grid, dependentValueToSelect) {
    jQuery("select", jQuery(formid)).each(function () {
        var name = jQuery.trim(jQuery(this).attr('name'));
        var tc = grid.jqGridi("getColProp", name);
        if (isObj(tc)) {
            var value = 0;
            var text = "";
            jQuery("option:selected", this).each(function () {
                value = jQuery.trim(jQuery(this).attr('value'));
                text = jQuery(this).attr('text');
            });

            if (tc['autocomplete'] == true) {
                jQuery(this).hide();
                addAutocomplete(this);
                if (this.updateInput) {
                    this.updateInput(text);
                }
            } else {
                jQuery(this).showRemoveDisplay();
                jQuery(this).change();
            }

            if (isCascade(tc)) {
                value = undefined;
                text = undefined;
                var child = tc['dependList'];
                var cp = grid.jqGridi("getColProp", child);

                var eo = cp['editoptions'];
                eo['dataUrl'] = eo['defaultDataUrl'].replace("param", value);
            }

            if (dependentValueToSelect) {
                setTimeout(function() {
                    jQuery("tr#tr_" + child + " td.DataTD select option:econtains('" + dependentValueToSelect + "')").attr("selected", "selected");
                }, 600);
            }
        }
    });
};

