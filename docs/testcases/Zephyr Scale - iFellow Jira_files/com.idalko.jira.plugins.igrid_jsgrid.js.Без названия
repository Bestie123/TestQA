    }
};

/**
 * @param grid - jqGrid object
 * @param rowid - id of the row to get data from
 * @param columnIds - array of column ids to set data for
 * Gets latest data for the row by iRow index from server
 * sets the latest data to the given columns
 * EXAMPLE:
 *  var formulaColumnIds = getFormulaColumnIdsForCField_${fieldId}();
 *  setLatestDataToRowByIdx(grid, iRow, formulaColumnIds);
 *  //fetches latest data for the row with id === rowid from server
 *  //sets it to the iRow for each of the formula columns
 * */
setLatestDataToRowById = function (grid, rowid, columnIds) {
    getRow(grid, rowid, function (data, st, xhr) {
        this.rowid = rowid;
        if (data) {
            var tableId = grid.prop('id');
            var fieldId = extractFieldId(tableId);
            JIRA.iDalko.TGE.managers.modelManager.updateRow(fieldId, this.rowid, data);
            if (data.cell) {
                if(columnIds && jQuery.isArray(columnIds) && columnIds.length > 0) {
                    findValuesFromRowForColumnsInGridAnd(data, columnIds, grid, function (rowid, columnIdx, columnValue) {

                        var dependentIRow = getIRow(rowid);
                        var notBeingEdited = isCellNotBeingEdited(grid, dependentIRow, columnIdx);
                        if (notBeingEdited) {
                            grid.jqGridi("setCell", rowid, columnIdx, columnValue, false, false, true);
                        }
                    });
                }
                grid[0].p.userData = jQuery.jgridi.getAccessor(data, grid[0].p.jsonReader.userdata) || {};
                if(grid[0].p.userData && grid[0].p.userDataOnFooter) {
                    grid.jqGridi("footerData", "set", grid[0].p.userData, true);
                }
            }
            var errors = $.jgridi.getAccessor(data, 'errors') || [];
            if (_.isArray(errors) && errors > 0 && (_.isFunction(grid[0].p.addValidationErrors))) {
                grid[0].p.addValidationErrors.call(grid[0], errors);
            }
        }
    }, function(xhr) {
        if (xhr.responseText && xhr.status) {
            $.jgridi.info_dialog($.jgridi.errors.errcap,xhr.status+" : "+xhr.responseText,$.jgridi.edit.bClose);
        }
    });
};


